rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Check if ID is a valid alphanumeric/hyphen/underscore string
    function isValidId(id) {
      return id.matches('^[a-zA-Z0-9_\\-]+$') && id.size() <= 64;
    }

    // Helper to validate Metrics schema
    function isValidMetrics(data) {
      return data.keys().hasAll(['totalMessages', 'uniqueUsers', 'messagesByModel'])
        && data.keys().size() == 3
        && data.totalMessages is int
        && data.uniqueUsers is list
        && data.messagesByModel is map;
    }

    // Helper to validate ActivityLog schema
    function isValidActivityLog(data) {
      return data.keys().hasAll(['timestamp', 'event'])
        && data.keys().size() == 2
        && data.timestamp is string
        && data.event is string
        && data.event.size() <= 256;
    }

    match /system_stats/{document} {
      allow read: if true;
      allow write: if isValidId(document) && isValidMetrics(request.resource.data);
    }

    match /activity_logs/{logId} {
      allow read: if true;
      allow create: if isValidId(logId) && isValidActivityLog(request.resource.data);
      allow update, delete: if false; // Only allow creation of logs, no edits or deletions
    }
  }
}
